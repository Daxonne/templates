{
  "name": "csharp-dapper",
  "version": "1.0.0",
  "language": "csharp",
  "description": "Generates C# records + Dapper queries",
  "author": "daxonne",
  "files": [
    {
      "template": "dto.hbs",
      "output": "{{PascalCase name}}Dto.cs",
      "per": "table"
    },
    {
      "template": "repository.hbs",
      "output": "{{PascalCase name}}Repository.cs",
      "per": "table"
    }
  ]
}
